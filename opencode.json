{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [ "bunx", "-y", "@modelcontextprotocol/server-sequential-thinking" ],
      "enabled": true
    },
    "ripgrep": {
      "type": "local",
      "command": ["bunx", "-y", "mcp-ripgrep@latest"],
      "enabled": true
    },
    "chunkhound": {
      "type": "local",
      "command": ["chunkhound", "mcp", "--db", "./data/chunks.duckdb", "--config", ".chunkhound.json", "--stdio", "$(pwd)"],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["bunx", "-y", "@modelcontextprotocol/server-filesystem", "/home/user/Documentos/radoc"],
      "enabled": true
    },
    "arxiv": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-v",
        "/home/user/Documentos/radoc/papers:/app/papers",
        "arxiv-mcp-server:local"
      ],
      "enabled": true
    },
    "neo4j-memory": {
      "type": "local",
      "command": [ "bunx", "@knowall-ai/mcp-neo4j-agent-memory" ],
      "enabled": true,
      "environment": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "<YOUR_NEO4J_PASSWORD>",
        "NEO4J_DATABASE": "neo4j"
      }
    },
    "design-patterns": {
      "type": "local",
      "command": ["bun", "/home/user/Documentos/design_patterns_mcp/dist/src/mcp-server.js" ],
      "enabled": true
    },
    "desktop-commander": {
      "type": "local",
      "command": ["npx",
        "-y",
        "@wonderwhy-er/desktop-commander@latest"],
      "enabled": true
    },
    "taskmanager": {
      "type": "local",
      "command": ["bun", "/home/user/Documentos/mcp-shrimp-task-manager/dist/index.js"],
      "enabled": true,
      "environment": {
        "DATA_DIR": "/home/user/Documentos/radoc/data/",
        "TEMPLATES_USE": "en",
        "ENABLE_GUI": "false"
      }
    },
    "knip": {
      "type": "local",
      "command": [ "bun", "/home/user/Documentos/knip-mcp-server/build/index.js" ],
      "enabled": true
    },
    "zen": {
      "type": "local",
      "command": [ "/home/user/Documentos/zen-mcp-server/.zen_venv/bin/python", "/home/user/Documentos/zen-mcp-server/server.py" ],
      "enabled": false
    },
    "shadcn": {
      "type": "local",
      "command": [ "bunx", "shadcn@latest", "mcp" ],
      "enabled": true
    },
    "radix-mcp-server": {
      "type": "local",
      "command": [ "bunx", "@gianpieropuleo/radix-mcp-server@latest", "--github-api-key", "<YOUR_<YOUR_GITHUB_API_KEY>>" ],
      "enabled": true
    },
    "flyonui": {
      "type": "local",
      "command": ["flyonui-mcp"],
      "enabled": true
    },
    "codemod": {
      "type": "local",
      "command": ["bunx", "codemod@latest", "mcp"],
      "enabled": true
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "spotlight": {
      "type": "local",
      "command": ["bunx", "-y", "--prefer-online", "@spotlightjs/spotlight@latest", "mcp"],
      "enabled": false
    },
    "codebase-state-manager": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--project",
        "/home/user/Documentos/radoc",
        "python",
        "/home/user/Documentos/codebase_state_manager_mcp/init_neo4j_and_mcp.py"
      ],
      "environment": {
        "DB_MODE": "sqlite",
        "NEO4J_ENABLED": "false",
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASSWORD": "<YOUR_NEO4J_PASSWORD>",
        "NEO4J_CONNECTION_TIMEOUT": "90",
        "LOG_LEVEL": "INFO",
        "RATE_LIMIT_ENABLED": "false",
        "AUDIT_ENABLED": "false",
        "VOLUME_PATH": "/tmp/radoc_branches/"
      },
      "enabled": true
    },
    "context-mode": {
      "type": "local",
      "command": ["context-mode"]
    },
    "ssh-server": {
      "type": "local",
      "command": ["node", "/home/user/Documentos/SSH-MCP/build/index.js"],
      "enabled": true,
      "environment": {
        "NODE_NO_WARNINGS": "1"
      }
    }
  },
  "plugin": ["context-mode", "@tarquinen/opencode-dcp@latest"]
}
